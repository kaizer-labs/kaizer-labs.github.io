<script is:inline>
  (() => {
    const bindAnalyticsEvents = () => {
      if (window.__kaizerAnalyticsEventsBound) return;

      document.addEventListener("click", (event) => {
        const target = event.target instanceof Element ? event.target.closest("[data-analytics-event]") : null;
        if (!target || typeof window.gtag !== "function") return;

        const eventName = target.getAttribute("data-analytics-event");
        if (!eventName) return;

        const label =
          target.getAttribute("data-analytics-label") ||
          target.getAttribute("href") ||
          target.textContent?.trim() ||
          "unknown";

        window.gtag("event", eventName, {
          event_category: "engagement",
          event_label: label
        });
      });

      window.__kaizerAnalyticsEventsBound = true;
    };

    document.addEventListener("astro:page-load", bindAnalyticsEvents);
    bindAnalyticsEvents();
  })();
</script>
