<div class="consent-banner" data-consent-banner hidden role="region" aria-live="polite" aria-label="Cookie preferences" aria-hidden="true">
  <div class="consent-banner__inner">
    <div>
      <p class="section-kicker">Preferences</p>
      <p class="consent-banner__copy">
        This portfolio stores a small local preference so the cookie controls feel integrated instead of outsourced.
      </p>
    </div>

    <div class="consent-banner__actions">
      <button class="button button--ghost" type="button" data-consent-action="essential">
        Essential only
      </button>
      <button class="button" type="button" data-consent-action="all">
        Allow preferences
      </button>
    </div>
  </div>
</div>

<script is:inline>
  const consentKey = "kaizer-portfolio-consent";

  const initConsentControls = () => {
    const banner = document.querySelector("[data-consent-banner]");
    const footerButtons = document.querySelectorAll("[data-open-consent]");
    const actionButtons = document.querySelectorAll("[data-consent-action]");

    if (!banner || banner.dataset.bound === "true") return;

    const safeStorage = {
      get(key) {
        try {
          return window.localStorage.getItem(key);
        } catch {
          return null;
        }
      },
      set(key, value) {
        try {
          window.localStorage.setItem(key, value);
        } catch {
          return false;
        }
        return true;
      }
    };

    const syncBannerSpace = () => {
      if (banner.hasAttribute("hidden")) {
        document.body.classList.remove("has-open-consent");
        document.documentElement.style.removeProperty("--consent-safe-space");
        return;
      }

      const safeSpace = Math.ceil(banner.getBoundingClientRect().height + 24);
      document.documentElement.style.setProperty("--consent-safe-space", `${safeSpace}px`);
      document.body.classList.add("has-open-consent");
    };

    const openBanner = ({ focusFirstAction = false } = {}) => {
      banner.removeAttribute("hidden");
      banner.setAttribute("aria-hidden", "false");
      window.requestAnimationFrame(() => {
        syncBannerSpace();
        if (focusFirstAction) banner.querySelector("[data-consent-action]")?.focus();
      });
    };

    const closeBanner = () => {
      banner.setAttribute("hidden", "");
      banner.setAttribute("aria-hidden", "true");
      syncBannerSpace();
    };

    if (!safeStorage.get(consentKey)) openBanner();

    footerButtons.forEach((button) => button.addEventListener("click", () => openBanner({ focusFirstAction: true })));
    actionButtons.forEach((button) =>
      button.addEventListener("click", () => {
        const value = button.getAttribute("data-consent-action") || "essential";
        safeStorage.set(consentKey, value);
        window.dispatchEvent(new CustomEvent("kaizer:consent-updated", { detail: value }));
        closeBanner();
      })
    );

    window.addEventListener("resize", syncBannerSpace);
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !banner.hasAttribute("hidden")) {
        closeBanner();
      }
    });

    banner.dataset.bound = "true";
  };

  document.addEventListener("astro:page-load", initConsentControls);
  initConsentControls();
</script>
