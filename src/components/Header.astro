---
import { site } from "../data/site";

const links = [
  { label: "Intro", href: "/#intro", id: "intro" },
  { label: "Proof", href: "/#proof", id: "proof" },
  { label: "Work", href: "/#work", id: "work" },
  { label: "Contact", href: "/#contact", id: "contact" }
];

const pathname = Astro.url.pathname;
const isHomePage = pathname === "/";
---

<header class="site-header">
  <div class="container header-row">
    <a class="brand" href="/">
      <span class="brand__name">{site.name}</span>
      <span class="brand__role">{site.role}</span>
    </a>

    <button
      class="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label="Open navigation menu"
      data-menu-toggle
    >
      <span class="menu-toggle__line"></span>
      <span class="menu-toggle__line"></span>
      <span class="menu-toggle__line"></span>
    </button>

    <nav class="main-nav" id="primary-nav" aria-label="Primary" data-primary-nav>
      {links.map((link) => (
        <a
          class:list={["nav-link", isHomePage && link.id === "intro" && "is-active"]}
          href={link.href}
          data-scroll-link={link.id}
          aria-current={isHomePage && link.id === "intro" ? "location" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <button class="theme-toggle" type="button" aria-label="Toggle color theme" title="Toggle color theme" data-theme-toggle>
        <span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4.25"></circle>
            <path d="M12 1.75v2.5"></path>
            <path d="M12 19.75v2.5"></path>
            <path d="M4.75 4.75l1.8 1.8"></path>
            <path d="M17.45 17.45l1.8 1.8"></path>
            <path d="M1.75 12h2.5"></path>
            <path d="M19.75 12h2.5"></path>
            <path d="M4.75 19.25l1.8-1.8"></path>
            <path d="M17.45 6.55l1.8-1.8"></path>
          </svg>
        </span>
        <span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.5 14.2A8.8 8.8 0 1 1 9.8 3.5a7.1 7.1 0 0 0 10.7 10.7Z"></path>
          </svg>
        </span>
        <span class="sr-only" data-theme-toggle-label>Dark mode</span>
      </button>
      <a class="nav-cta" href="/#contact" data-analytics-event="contact_click" data-analytics-label="header_connect">Connect</a>
    </div>
  </div>
</header>
<div class="scroll-progress" aria-hidden="true" data-scroll-progress></div>

<script>
  const toggle = document.querySelector("[data-theme-toggle]");
  const label = document.querySelector("[data-theme-toggle-label]");
  const themeMeta = document.querySelector('meta[name="theme-color"]');
  const menuToggle = document.querySelector("[data-menu-toggle]");
  const primaryNav = document.querySelector("[data-primary-nav]");
  const header = document.querySelector(".site-header");
  const scrollProgress = document.querySelector("[data-scroll-progress]");
  const scrollLinks = Array.from(document.querySelectorAll("[data-scroll-link]"));
  const scrollSections = Array.from(document.querySelectorAll("[data-scroll-section]"));
  const isHomePage = window.location.pathname === "/" || window.location.pathname === "/index.html";
  let scrollRaf = 0;
  const knownSectionIds = new Set(scrollSections.map((section) => section.id).filter(Boolean));
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const safeStorage = {
    get(key) {
      try {
        return window.localStorage.getItem(key);
      } catch {
        return null;
      }
    },
    set(key, value) {
      try {
        window.localStorage.setItem(key, value);
      } catch {
        return false;
      }
      return true;
    }
  };

  const syncHeaderHeight = () => {
    if (!(header instanceof HTMLElement)) return;
    document.documentElement.style.setProperty("--header-height", `${Math.ceil(header.offsetHeight)}px`);
  };

  const syncThemeUi = (theme) => {
    if (!toggle || !label) return;
    label.textContent = theme === "dark" ? "Light mode" : "Dark mode";
    toggle.setAttribute("aria-pressed", theme === "dark" ? "true" : "false");
    themeMeta?.setAttribute("content", theme === "dark" ? "#08111f" : "#f6f3ec");
  };

  const applyTheme = (theme) => {
    document.documentElement.dataset.theme = theme;
    safeStorage.set("theme-preference", theme);
    syncThemeUi(theme);
  };

  const initialTheme = document.documentElement.dataset.theme || "light";
  syncThemeUi(initialTheme);

  toggle?.addEventListener("click", () => {
    const nextTheme = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
    applyTheme(nextTheme);
  });

  const closeMenu = ({ restoreFocus = false } = {}) => {
    if (!menuToggle || !primaryNav) return;
    menuToggle.setAttribute("aria-expanded", "false");
    menuToggle.setAttribute("aria-label", "Open navigation menu");
    primaryNav.removeAttribute("data-open");
    if (restoreFocus) menuToggle.focus();
  };

  menuToggle?.addEventListener("click", () => {
    if (!primaryNav) return;
    const isOpen = menuToggle.getAttribute("aria-expanded") === "true";
    const nextState = String(!isOpen);
    menuToggle.setAttribute("aria-expanded", nextState);
    menuToggle.setAttribute("aria-label", isOpen ? "Open navigation menu" : "Close navigation menu");
    if (isOpen) {
      primaryNav.removeAttribute("data-open");
    } else {
      primaryNav.setAttribute("data-open", "true");
    }
  });

  primaryNav?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => closeMenu());
  });

  const setActiveLink = (sectionId) => {
    scrollLinks.forEach((link) => {
      const isActive = link.getAttribute("data-scroll-link") === sectionId;
      link.classList.toggle("is-active", isActive);
      if (isActive) {
        link.setAttribute("aria-current", "location");
      } else {
        link.removeAttribute("aria-current");
      }
    });
  };

  const navSectionFor = (section) => {
    if (!(section instanceof HTMLElement)) return section?.id || "intro";
    return section.dataset.navSection || section.id || "intro";
  };

  const updateScrollProgress = () => {
    if (!(scrollProgress instanceof HTMLElement)) return;
    const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
    const progress = maxScroll > 0 ? Math.min(Math.max(window.scrollY / maxScroll, 0), 1) : 0;
    scrollProgress.style.transform = `scaleX(${progress})`;
  };

  const updateActiveFromScroll = () => {
    if (!scrollSections.length) return;
    syncHeaderHeight();
    const headerHeight = header instanceof HTMLElement && getComputedStyle(header).position === "sticky" ? header.offsetHeight : 0;
    const sampleLine = headerHeight + Math.min(window.innerHeight * 0.36, 240);
    let activeSection = navSectionFor(scrollSections[0]);

    scrollSections.forEach((section) => {
      const rect = section.getBoundingClientRect();
      if (rect.top <= sampleLine) {
        activeSection = navSectionFor(section);
      }
    });

    setActiveLink(activeSection);
  };

  const requestActiveUpdate = () => {
    if (scrollRaf) return;
    scrollRaf = window.requestAnimationFrame(() => {
      scrollRaf = 0;
      updateScrollProgress();
      updateActiveFromScroll();
    });
  };

  syncHeaderHeight();
  updateScrollProgress();

  if (header instanceof HTMLElement && "ResizeObserver" in window) {
    const headerObserver = new ResizeObserver(syncHeaderHeight);
    headerObserver.observe(header);
  }

  if (isHomePage && scrollSections.length > 0) {
    const initialSection = window.location.hash.replace("#", "") || "intro";
    const initialTarget = document.getElementById(initialSection);
    setActiveLink(initialTarget instanceof HTMLElement ? navSectionFor(initialTarget) : "intro");

    scrollLinks.forEach((link) => {
      link.addEventListener("click", () => {
        const sectionId = link.getAttribute("data-scroll-link");
        if (sectionId) setActiveLink(sectionId);
      });
    });

    window.addEventListener("scroll", requestActiveUpdate, { passive: true });
    window.addEventListener("load", requestActiveUpdate);

    window.addEventListener("hashchange", () => {
      const sectionId = window.location.hash.replace("#", "");
      if (sectionId && knownSectionIds.has(sectionId)) {
        const section = document.getElementById(sectionId);
        setActiveLink(navSectionFor(section));
      } else {
        updateActiveFromScroll();
      }
      window.setTimeout(requestActiveUpdate, 80);
    });

    requestActiveUpdate();

    if (!prefersReducedMotion && "IntersectionObserver" in window) {
      scrollSections.forEach((section) => {
        section.setAttribute("data-reveal", section.id === "intro" ? "visible" : "pending");
      });
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.setAttribute("data-reveal", "visible");
            revealObserver.unobserve(entry.target);
          });
        },
        { rootMargin: "0px 0px -12% 0px", threshold: 0.12 }
      );
      scrollSections.forEach((section) => revealObserver.observe(section));
    }
  } else {
    scrollLinks.forEach((link) => link.removeAttribute("aria-current"));
  }

  window.addEventListener("resize", () => {
    syncHeaderHeight();
    updateScrollProgress();
    if (window.innerWidth > 959) {
      closeMenu();
    }
    requestActiveUpdate();
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && primaryNav?.hasAttribute("data-open")) {
      closeMenu({ restoreFocus: true });
    }
  });

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element) || !primaryNav?.hasAttribute("data-open")) return;
    if (!target.closest(".site-header")) {
      closeMenu();
    }
  });
</script>
